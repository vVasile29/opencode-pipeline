#!/usr/bin/env bash
# opencode-pipeline-fallback — Interactive fzf-based model swapper for pipeline agents
#
# Usage:
#   opencode-pipeline-fallback                    # interactive: pick agent, then model
#   opencode-pipeline-fallback <agent>            # pick model for specific agent
#   opencode-pipeline-fallback --auto <agent>     # auto-assign next best free model
#   opencode-pipeline-fallback --list             # show all agents and their models
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/opencode"
AGENTS_DIR="$CONFIG_DIR/agents"
CACHE_FILE="${HOME}/.cache/opencode/models.json"
ROLES_FILE="$(cd "$(dirname "$0")" && pwd)/models/roles.json"
BIN_DIR="${HOME}/.local/bin"
SCRIPT_NAME="$(basename "$0")"

usage() {
  echo "Usage: $SCRIPT_NAME [--auto|--list] [<agent-name>]"
  echo ""
  echo "  (no args)    Interactive: pick an agent, then pick a model via fzf"
  echo "  <agent>       Skip agent pick, go straight to model selection"
  echo "  --auto <agent> Auto-assign next best free model (non-interactive)"
  echo "  --list        Show all agents and their current models"
  exit 0
}

# ── List agents and their current models ──────────────────────────
list_agents() {
  echo "Pipeline Agents and their current models:"
  echo ""
  if [[ ! -d "$AGENTS_DIR" ]]; then
    echo "  (no agents directory at $AGENTS_DIR)"
    exit 1
  fi
  for f in "$AGENTS_DIR"/*.md; do
    name=$(basename "$f" .md)
    model=$(sed -n 's/^model: //p' "$f" | head -1)
    mode=$(sed -n 's/^mode: //p' "$f" | head -1)
    printf "  %-15s %-55s [%s]\n" "$name" "${model:-unknown}" "${mode:-subagent}"
  done
}

# ── Detect agent's current model ──────────────────────────────────
get_current_model() {
  local agent="$1"
  local file="$AGENTS_DIR/$agent.md"
  if [[ ! -f "$file" ]]; then
    echo ""
    return
  fi
  sed -n 's/^model: //p' "$file" | head -1
}

# ── List available free models with tool_call ────────────────────
list_free_models() {
  if [[ ! -f "$CACHE_FILE" ]]; then
    echo "[]"
    return
  fi
  python3 -c "
import json, sys

with open('$CACHE_FILE') as f:
    data = json.load(f)

opencode = data.get('opencode', {})
models = opencode.get('models', {})

available = []
for mid, m in models.items():
    if not isinstance(m, dict):
        continue
    status = m.get('status', '')
    if status == 'deprecated':
        continue
    cost = m.get('cost', {})
    if not (isinstance(cost, dict) and cost.get('input', 1) == 0):
        continue
    available.append({
        'id': mid,
        'name': m.get('name', mid),
        'reasoning': m.get('reasoning', False),
        'tool_call': m.get('tool_call', False),
        'structured_output': m.get('structured_output', False),
        'context': m.get('limit', {}).get('context', 0),
        'output': m.get('limit', {}).get('output', 0),
    })

available.sort(key=lambda x: (-x.get('context', 0), -x.get('output', 0), x['id']))
json.dump(available, sys.stdout, indent=2)
"
}

# ── Auto-assign next best model for an agent ──────────────────────
auto_assign() {
  local agent="$1"
  local roles_file="$2"
  local free_json
  free_json=$(list_free_models)

  local count
  count=$(echo "$free_json" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))")
  if [[ "$count" -eq 0 ]]; then
    echo "  ✗ No free models available — models cache empty or unreachable."
    return 1
  fi

  local current
  current=$(get_current_model "$agent" | sed 's|^opencode/||')

  local result
  result=$(echo "$free_json" | python3 -c "
import json, sys, os

free = json.load(sys.stdin)
try:
    with open('$roles_file') as f:
        roles_data = json.load(f)
    role = roles_data.get('roles', {}).get('$agent', {})
except Exception:
    role = {'requires': ['tool_call'], 'prefers': {}, 'min_context': 16000, 'min_output': 4000}

def score_model(m, r):
    for req in r.get('requires', []):
        if req == 'reasoning' and not m.get('reasoning'):
            return -1
        if req == 'tool_call' and not m.get('tool_call'):
            return -1
    ctx = m.get('context', 0)
    out = m.get('output', 0)
    if ctx < r.get('min_context', 0):
        return -1
    if out < r.get('min_output', 0):
        return -1
    prefs = r.get('prefers', {})
    score = 1.0
    if prefs.get('reasoning', 0) and m.get('reasoning'):
        bonus = prefs['reasoning'] * 2
        ropts = m.get('reasoning_options')
        if not ropts or ropts == []:
            bonus += prefs['reasoning']
        score += bonus
    if prefs.get('tool_call', 0) and m.get('tool_call'):
        score += prefs['tool_call']
    if prefs.get('structured_output', 0) and m.get('structured_output'):
        score += prefs['structured_output']
    if prefs.get('context', 0):
        score += prefs['context'] * min(ctx / 200000, 2.0)
    if prefs.get('output', 0):
        score += prefs['output'] * min(out / 32000, 3.0)
    return score

current_id = '$current'
scored = [(score_model(m, role), m) for m in free]
scored = [(s, m) for s, m in scored if s >= 0]
scored.sort(key=lambda x: (-x[0], x[1]['id']))

if not scored:
    print('NO_MODEL')
    sys.exit(0)

# Skip current model, pick next best
for s, m in scored:
    if m['id'] != current_id:
        print(m['id'])
        sys.exit(0)

# If only current model exists, re-pick it
print(scored[0][1]['id'])
")

  if [[ "$result" == "NO_MODEL" ]]; then
    echo "  ✗ No suitable free models found for '$agent'."
    return 1
  fi

  echo "$result"
}

# ── Update agent's model frontmatter ─────────────────────────────
update_agent_model() {
  local agent="$1"
  local new_model="$2"
  local file="$AGENTS_DIR/$agent.md"

  if [[ ! -f "$file" ]]; then
    echo "  ✗ Agent file not found: $file"
    return 1
  fi

  # Get current model for display
  local old_model
  old_model=$(get_current_model "$agent")

  # Update model line in YAML frontmatter (between --- markers)
  if [[ "$(uname)" == "Darwin" ]]; then
    sed -i '' "s|^model: opencode/.*|model: opencode/$new_model|" "$file"
  else
    sed -i "s|^model: opencode/.*|model: opencode/$new_model|" "$file"
  fi

  echo "  $agent: $old_model → opencode/$new_model"
}

# ── Main ─────────────────────────────────────────────────────────
MODE="interactive"
TARGET=""

for arg in "$@"; do
  case "$arg" in
    --help|-h) usage ;;
    --list) MODE="list" ;;
    --auto) MODE="auto" ;;
    --*) echo "Unknown option: $arg"; usage ;;
    *) TARGET="$arg" ;;
  esac
done

case "$MODE" in
  list)
    list_agents
    exit 0
    ;;
  auto)
    if [[ -z "$TARGET" ]]; then
      echo "Usage: $SCRIPT_NAME --auto <agent-name>"
      exit 1
    fi
    echo "==> Auto-assigning model for '$TARGET'..."
    new_model=$(auto_assign "$TARGET" "$ROLES_FILE")
    if [[ -z "$new_model" || "$new_model" == "NO_MODEL" ]]; then
      echo "  ✗ No suitable fallback model found. Run '$SCRIPT_NAME $TARGET' to pick manually."
      exit 1
    fi
    update_agent_model "$TARGET" "$new_model"
    echo "  ✓ Done. Retry the pipeline."
    exit 0
    ;;
  interactive)
    # If no agent specified, let user pick one
    if [[ -z "$TARGET" ]]; then
      if [[ ! -d "$AGENTS_DIR" ]]; then
        echo "Agents not installed. Run 'install.sh' first."
        exit 1
      fi

      choices=$(list_agents | tail -n +2 | fzf --height=40% --prompt="Pick an agent > " --header="Pipeline Agents" | awk '{print $1}')
      TARGET="$choices"
      if [[ -z "$TARGET" ]]; then
        echo "No agent selected."
        exit 0
      fi
    fi

    # Check agent exists
    local agent_file="$AGENTS_DIR/$TARGET.md"
    if [[ ! -f "$agent_file" ]]; then
      echo "  ✗ Agent '$TARGET' not found (expected $agent_file)"
      echo "  Available agents:"
      list_agents | tail -n +2 | sed 's/^/    /'
      exit 1
    fi

    # Show current model
    current=$(get_current_model "$TARGET")
    echo "==> Agent: $TARGET"
    echo "    Current model: ${current:-none}"

    # Fetch free models
    free_json=$(list_free_models)
    model_count=$(echo "$free_json" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))")
    if [[ "$model_count" -eq 0 ]]; then
      echo "    ✗ No free models found in models cache."
      echo "    Run 'opencode' once to populate $CACHE_FILE"
      exit 1
    fi

    # Build fzf preview + pick
    selected=$(echo "$free_json" | python3 -c "
import json, sys

models = json.load(sys.stdin)
for m in models:
    ctx = m.get('context', 0)
    out = m.get('output', 0)
    reason = '✓' if m.get('reasoning') else '✗'
    tool = '✓' if m.get('tool_call') else '✗'
    struct = '✓' if m.get('structured_output') else '✗'
    print(f'{m[\"id\"]:45s}  {m[\"name\"]:40s}  ctx={ctx:<7}  out={out:<6}  rsn={reason}  tool={tool}  struct={struct}')
" | fzf --height=60% --prompt="Pick a model for '$TARGET' > " \
         --header="Current: ${current:-none}    (↑↓ navigate, enter select, esc cancel)" \
         --with-nth=1 --delimiter=' ')

    model_id=$(echo "$selected" | awk '{print $1}')
    if [[ -z "$model_id" ]]; then
      echo "    No model selected."
      exit 0
    fi

    update_agent_model "$TARGET" "$model_id"
    echo ""
    echo "  ✓ Done. Re-run 'opencode' or continue your session."
    ;;
esac
